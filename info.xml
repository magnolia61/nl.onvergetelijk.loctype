<?xml version="1.0"?>
<extension key="nl.onvergetelijk.loctype" type="module">
  <file>loctype</file>
  <name>nl.onvergetelijk.loctype</name>
  <description>Force specific email location types for scheduled reminders</description>
  <license>AGPL-3.0</license>
  <maintainer>
    <author>Richard van Oosterhout</author>
    <email>webteam@onvergetelijk.nl</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://www.onvergetelijk.nl</url>
    <url desc="Documentation">https://www.onvergetelijk.nl</url>
    <url desc="Support">https://www.onvergetelijk.nl</url>
    <url desc="Licensing">https://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2026-03-06</releaseDate>
  <version>1.0.0</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>6.12</ver>
  </compatibility>
  <comments>Onderschept FlexMailer pipeline om email routing te forceren</comments>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi/"/>
  </classloader>
  <civix>
    <namespace>CRM/Loctype</namespace>
    <format>25.01.1</format>
    <angularModule>crmLoctype</angularModule>
  </civix>
  <mixins>
    <mixin>mgd-php@1.0.0</mixin>
    <mixin>setting-php@1.0.0</mixin>
    <mixin>scan-classes@1.0.0</mixin>
    <mixin>smarty@1.0.3</mixin>
  </mixins>
</extension>
